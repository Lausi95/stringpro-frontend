# Build context hygiene — keep the image build small and reproducible.
# Anything the `pnpm build` doesn't need should be excluded so a stale local
# artifact (e.g. dist/) can never leak into the image.
node_modules
dist
.git
.github
.claude
docs
*.md
Dockerfile
.dockerignore
.vscode
.idea
.DS_Store
npm-debug.log*
pnpm-debug.log*
